<script name="onmount">
    this.def("users", []);
    fetch("https://jsonplaceholder.typicode.com/users")
        .then(e => e.json())
        .then(e => this.set("users", e))
        .catch(e => console.log(e));
</script>

<template name="main">
    <ul>
        ${ this.users.map(e => this.use("user.lgs", e)).join("") }
    </ul>
</template>